{
  "name": "modern-react-components",
  "version": "1.0.0",
  "description": "Modern React components collection",
  "private": false,
  "type": "module",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js"
    },
    "./badge": {
      "types": "./dist/components/Badge/index.d.ts",
      "style": "./dist/components/Badge/Badge.css",
      "import": "./dist/components/Badge/index.es.js",
      "require": "./dist/components/Badge/index.cjs.js"
    },
    "./button": {
      "types": "./dist/components/Button/index.d.ts",
      "style": "./dist/components/Button/Button.css",
      "import": "./dist/components/Button/index.es.js",
      "require": "./dist/components/Button/index.cjs.js"
    },
    "./digitalclock": {
      "types": "./dist/components/DigitalClock/index.d.ts",
      "style": "./dist/components/DigitalClock/DigitalClock.css",
      "import": "./dist/components/DigitalClock/index.es.js",
      "require": "./dist/components/DigitalClock/index.cjs.js"
    },
    "./dropdown": {
      "types": "./dist/components/Dropdown/index.d.ts",
      "style": "./dist/components/Dropdown/Dropdown.css",
      "import": "./dist/components/Dropdown/index.es.js",
      "require": "./dist/components/Dropdown/index.cjs.js"
    },
    "./input": {
      "types": "./dist/components/Input/index.d.ts",
      "style": "./dist/components/Input/Input.css",
      "import": "./dist/components/Input/index.es.js",
      "require": "./dist/components/Input/index.cjs.js"
    },
    "./modal": {
      "types": "./dist/components/Modal/index.d.ts",
      "style": "./dist/components/Modal/Modal.css",
      "import": "./dist/components/Modal/index.es.js",
      "require": "./dist/components/Modal/index.cjs.js"
    },
    "./table": {
      "types": "./dist/components/Table/index.d.ts",
      "style": "./dist/components/Table/Table.css",
      "import": "./dist/components/Table/index.es.js",
      "require": "./dist/components/Table/index.cjs.js"
    }
  },
  "scripts": {
    "sandbox": "vite --config vite.sandbox.config.ts",
    "dev": "vite",
    "build": "rimraf dist && vite build && npm run generate-exports",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "generate-exports": "node scripts/generate-exports.js",
    "create-component": "node scripts/generate-component.js && node scripts/generate-exports.js",
    "delete-component": "node scripts/delete-component.js",
    "sync-components": "node scripts/sync-components.js"
  },
  "keywords": [
    "react",
    "components",
    "ui",
    "library"
  ],
  "author": "",
  "license": "ISC",
  "peerDependencies": {
    "react": ">=18 <20",
    "react-dom": ">=18 <20"
  },
  "devDependencies": {
    "@inquirer/prompts": "^8.3.0",
    "@types/node": "^20.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "chalk": "^5.6.2",
    "fast-glob": "^3.3.3",
    "pkg": "^5.8.1",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "publishConfig": {
    "access": "public"
  }
}
